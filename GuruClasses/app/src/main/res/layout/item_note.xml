<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardElevation="4dp"
    app:cardCornerRadius="12dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="16dp" android:gravity="center_vertical">

        <LinearLayout android:layout_width="50dp" android:layout_height="50dp"
            android:background="@color/subject_english" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="&#128196;" android:textSize="24sp" />
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical"
            android:layout_marginStart="12dp">
            <TextView android:id="@+id/tvNoteTitle" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:text="Note Title"
                android:textSize="15sp" android:textColor="@color/text_primary"
                android:textStyle="bold" android:maxLines="2" />
            <TextView android:id="@+id/tvNoteSubject" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Subject"
                android:textSize="12sp" android:textColor="@color/accent"
                android:layout_marginTop="4dp" />
            <TextView android:id="@+id/tvNoteDesc" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:text="Description"
                android:textSize="12sp" android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp" android:maxLines="1" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton android:id="@+id/btnDownload"
            style="@style/ButtonAccent" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Open"
            android:textSize="12sp" android:paddingStart="12dp" android:paddingEnd="12dp" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
